   "source": [
    "import numpy as np\n",
    "from scipy.special import comb"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "36b31af4",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "0.9791033089952937\n"
     ]
    }
   ],
   "source": [
    "N = 101\n",
    "p = 0.6\n",
    "\n",
    "def P(k : int) -> np.float64:\n",
    "    return comb(N, k) * np.pow(p, k) * pow(1-p, N-k)\n",
    "\n",
    "res = sum(P(k) for k in range(51, 102))\n",
    "\n",
    "print(res)"
   ]
  }
 ],
